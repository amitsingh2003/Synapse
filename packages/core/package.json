{
  "name": "@synapse/core",
  "version": "0.0.0",
  "private": true,
  "description": "Core indexing engine: parser, DB layer, SCIP integration, watcher, synthesizer",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.3",
    "cli-progress": "^3.12.0",
    "ignore": "^7.0.5",
    "piscina": "^4.8.0",
    "tree-sitter-wasms": "^0.1.12",
    "web-tree-sitter": "^0.24.5",
    "xxhash-wasm": "^1.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^22.10.0",
    "fast-check": "^4.8.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
